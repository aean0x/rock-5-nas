{
  "meta": {
    "lastTouchedVersion": "2026.2.21",
    "lastTouchedAt": "2026-02-25T07:13:37.735Z"
  },
  "wizard": {
    "lastRunAt": "2026-02-18T17:46:21.007Z",
    "lastRunVersion": "2026.2.16",
    "lastRunCommand": "doctor",
    "lastRunMode": "local"
  },
  "logging": {
    "redactSensitive": "tools"
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": false,
    "defaultProfile": "remote",
    "profiles": {
      "remote": {
        "cdpUrl": "https://production-ams.browserless.io/?token=${BROWSERLESS_API_TOKEN}&stealth=true&blockAds=true",
        "color": "#00AA00"
      },
      "local": {
        "cdpPort": 18800,
        "color": "#FF0000"
      }
    }
  },
  "auth": {
    "profiles": {
      "xai:default": {
        "provider": "xai",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "xai": {
        "baseUrl": "https://api.x.ai/v1",
        "apiKey": "${XAI_API_KEY}",
        "api": "openai-responses",
        "models": [
          {
            "id": "grok-4-1-fast-non-reasoning",
            "name": "Grok 4.1 Fast"
          },
          {
            "id": "grok-4-1-fast-reasoning",
            "name": "Grok 4.1 Fast Reasoning"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "xai/grok-4-1-fast-reasoning",
        "fallbacks": ["xai/grok-4-1-fast-non-reasoning"]
      },
      "models": {
        "xai/grok-4-1-fast-reasoning": {
          "alias": "grok-reasoning"
        },
        "xai/grok-4-1-fast-non-reasoning": {
          "alias": "grok-non-reasoning"
        }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "memorySearch": {
        "provider": "gemini",
        "remote": {
          "apiKey": "${GEMINI_API_KEY}"
        },
        "model": "gemini-embedding-001"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "12h",
        "keepLastAssistants": 3,
        "softTrimRatio": 0.3,
        "hardClearRatio": 0.5
      },
      "compaction": {
        "mode": "default",
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 40000,
          "prompt": "Extract key decisions, state changes, lessons, blockers to memory/YYYY-MM-DD.md. Format: ## [HH:MM] Topic. Skip routine work. NO_FLUSH if nothing important.",
          "systemPrompt": "Compacting session context. Extract only what's worth remembering. No fluff."
        }
      },
      "subagents": {
        "model": "xai/grok-4-1-fast-reasoning"
      },
      "sandbox": {
        "mode": "non-main",
        "workspaceAccess": "none",
        "scope": "agent",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "readOnlyRoot": true,
          "network": "bridge",
          "user": "1000:1000",
          "capDrop": ["ALL"],
          "env": {
            "HOME": "/home/node",
            "OPENCLAW_HOME": "/home/node",
            "OPENCLAW_STATE_DIR": "/home/node/.openclaw",
            "OPENCLAW_CONFIG_PATH": "/home/node/.openclaw/openclaw.json",
            "OPENCLAW_GATEWAY_TOKEN": "${OPENCLAW_GATEWAY_TOKEN}",
            "OPENCLAW_GATEWAY_URL": "ws://172.17.0.1:18789"
          },
          "cpus": 1
        },
        "browser": {
          "enabled": true
        }
      }
    },
    "list": [
      {
        "id": "main",
        "subagents": {
          "allowAgents": ["*"]
        },
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "profile": "full",
          "deny": ["group:web", "group:email", "group:messaging", "group:ui"]
        }
      },
      {
        "id": "researcher",
        "workspace": "/home/node/.openclaw/workspace/sub-agents/researcher",
        "memorySearch": {
          "enabled": false
        },
        "identity": {
          "name": "Researcher"
        },
        "sandbox": {
          "workspaceAccess": "rw",
          "docker": {
            "network": "bridge",
            "env": {
              "BRAVE_API_KEY": "${BRAVE_API_KEY}",
              "GOOGLE_PLACES_API_KEY": "${GOOGLE_PLACES_API_KEY}",
              "OPENCLAW_GATEWAY_TOKEN": "${OPENCLAW_GATEWAY_TOKEN}",
              "OPENCLAW_GATEWAY_URL": "ws://172.17.0.1:18789"
            },
            "extra_hosts": ["host.docker.internal:host-gateway"]
          },
          "tools": {
            "allow": ["group:web", "read", "group:memory", "session_status"]
          }
        },
        "tools": {
          "allow": [
            "group:web",
            "read",
            "group:memory",
            "sessions_list",
            "session_status"
          ]
        }
      },
      {
        "id": "communicator",
        "workspace": "/home/node/.openclaw/workspace/sub-agents/communicator",
        "identity": {
          "name": "Communicator"
        },
        "sandbox": {
          "workspaceAccess": "rw",
          "docker": {
            "network": "bridge",
            "env": {
              "MATON_API_KEY": "${MATON_API_KEY}",
              "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}",
              "OPENCLAW_GATEWAY_TOKEN": "${OPENCLAW_GATEWAY_TOKEN}",
              "OPENCLAW_GATEWAY_URL": "ws://172.17.0.1:18789"
            }
          }
        },
        "tools": {
          "allow": [
            "group:messaging",
            "group:email",
            "write",
            "read",
            "sessions_list",
            "session_status"
          ]
        }
      },
      {
        "id": "controller",
        "workspace": "/home/node/.openclaw/workspace/sub-agents/controller",
        "identity": {
          "name": "Controller"
        },
        "sandbox": {
          "workspaceAccess": "rw",
          "docker": {
            "network": "bridge",
            "env": {
              "HA_URL": "${HA_URL}",
              "HA_TOKEN": "${HA_TOKEN}",
              "OPENCLAW_GATEWAY_TOKEN": "${OPENCLAW_GATEWAY_TOKEN}",
              "OPENCLAW_GATEWAY_URL": "ws://172.17.0.1:18789"
            }
          }
        },
        "tools": {
          "allow": [
            "group:ha",
            "mcp",
            "read",
            "sessions_list",
            "session_status"
          ]
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "maxResults": 5
      },
      "fetch": {
        "enabled": true,
        "maxChars": 50000
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "main": ["*"],
        "telegram": ["${TELEGRAM_ADMIN_ID}"]
      }
    },
    "exec": {
      "security": "full",
      "ask": "off"
    },
    "sandbox": {
      "tools": {
        "deny": [
          "browser",
          "canvas",
          "nodes",
          "cron",
          "gateway",
          "telegram",
          "whatsapp",
          "discord",
          "irc",
          "googlechat",
          "slack",
          "signal",
          "imessage"
        ]
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions",
    "tts": {
      "auto": "inbound",
      "provider": "edge",
      "edge": {
        "enabled": true,
        "voice": "en-GB-RyanNeural"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "text": true,
    "bash": false,
    "config": true,
    "restart": true,
    "ownerDisplay": "raw"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        },
        "bootstrap-extra-files": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streamMode": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "enabled": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "allowTailscale": true
    },
    "trustedProxies": ["127.0.0.1", "::1"],
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  }
}
